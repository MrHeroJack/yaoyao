VITE_STORAGE_PROVIDER=link-only
VITE_UPLOAD_MAX_SIZE_MB=5
# 可选：构建时指定七牛访问域名（优先级低于后端 QINIU_PUBLIC_URL）
VITE_QINIU_PUBLIC_URL=
# 可选：构建时指定七牛区域（z0/z1/z2/na0/as0）
VITE_QINIU_REGION=z0

ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=1800
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 推荐：运行时指定七牛区域（z0/z1/z2/na0/as0）
QINIU_REGION=z0
# 必填：七牛公开访问域名，如 https://xxx.your-domain.com
QINIU_PUBLIC_URL=

ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=
ALI_OSS_BUCKET=
